{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Graphite SEC Benchmark Case",
  "description": "Schema for a single benchmark case in sec_cases.jsonl. Each line in the JSONL file must conform to this schema.",
  "type": "object",
  "required": ["case_id", "ticker", "source_docs", "memo_text", "claims"],
  "properties": {
    "case_id": {
      "type": "string",
      "description": "Unique identifier for this case, e.g. 'SEC-AAPL-2024Q4-001'",
      "pattern": "^SEC-[A-Z]+-[0-9A-Za-z]+-[0-9]+$"
    },
    "ticker": {
      "type": "string",
      "description": "Stock ticker symbol, e.g. 'AAPL', 'NVDA', 'TSLA'"
    },
    "filing_type": {
      "type": "string",
      "description": "Type of SEC filing used as source",
      "enum": ["10-K", "10-Q", "8-K", "earnings_call", "press_release", "mixed"]
    },
    "fiscal_period": {
      "type": "string",
      "description": "Fiscal period covered, e.g. 'FY2024', 'Q3-2024'"
    },
    "generation_method": {
      "type": "string",
      "description": "How the memo was created",
      "enum": ["semi_synthetic", "fully_synthetic", "real_memo", "human_written"]
    },
    "source_docs": {
      "type": "array",
      "description": "Source documents (SEC filings, earnings calls, press releases)",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["doc_id", "doc_type", "text"],
        "properties": {
          "doc_id": {
            "type": "string",
            "description": "Unique document ID, e.g. 'AAPL-10K-2024'"
          },
          "doc_type": {
            "type": "string",
            "enum": ["10-K", "10-Q", "8-K", "earnings_call_transcript", "press_release"]
          },
          "source_url": {
            "type": "string",
            "description": "EDGAR URL or other public source URL"
          },
          "accession_number": {
            "type": "string",
            "description": "SEC accession number if applicable"
          },
          "text": {
            "type": "string",
            "description": "Full or excerpted text content"
          },
          "spans": {
            "type": "array",
            "description": "Named spans within the document for citation",
            "items": {
              "type": "object",
              "required": ["span_id", "text"],
              "properties": {
                "span_id": {
                  "type": "string",
                  "description": "Unique span identifier, e.g. 'AAPL-10K-2024-p12'"
                },
                "text": {
                  "type": "string"
                },
                "section": {
                  "type": "string",
                  "description": "Section name, e.g. 'Risk Factors', 'MD&A'"
                },
                "paragraph_index": {
                  "type": "integer"
                }
              }
            }
          }
        }
      }
    },
    "memo_text": {
      "type": "string",
      "description": "The full AI-generated memo or claim paragraph to verify"
    },
    "claims": {
      "type": "array",
      "description": "Individual claims extracted from the memo (4-6 per case)",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["claim_id", "claim_text", "gold_verdict", "gold_argument_verdict"],
        "properties": {
          "claim_id": {
            "type": "string",
            "description": "Unique claim ID, e.g. 'SEC-AAPL-2024Q4-001-c1'"
          },
          "claim_text": {
            "type": "string",
            "description": "The specific claim statement"
          },
          "gold_verdict": {
            "type": "string",
            "description": "Ground truth claim verdict",
            "enum": ["SUPPORTED", "CONFLICTED", "INSUFFICIENT"]
          },
          "gold_argument_verdict": {
            "type": "string",
            "description": "Ground truth argument-level verdict",
            "enum": ["GROUNDED", "CONCLUSION_JUMP", "OVERSTATED"]
          },
          "needs_human_review": {
            "type": "boolean",
            "description": "Whether this claim should be flagged for human review",
            "default": false
          },
          "gold_cited_span_ids": {
            "type": "array",
            "description": "Span IDs from source_docs that justify the verdict",
            "items": {
              "type": "string"
            }
          },
          "failure_mode": {
            "type": ["string", "null"],
            "description": "Type of error present (null if SUPPORTED+GROUNDED)",
            "enum": [
              "numeric_mismatch",
              "temporal_mismatch",
              "paraphrased_contradiction",
              "unsupported_extrapolation",
              "missing_evidence",
              "retrieval_noise",
              null
            ]
          },
          "difficulty": {
            "type": "string",
            "description": "Subjective difficulty for a human reviewer",
            "enum": ["easy", "medium", "hard"]
          },
          "canonical_claim_id": {
            "type": "string",
            "description": "If this claim is a variant of a canonical claim (for stateful ablation), reference the canonical ID here. Empty string if not applicable.",
            "default": ""
          },
          "annotator_notes": {
            "type": "string",
            "description": "Optional notes from the annotator about this claim",
            "default": ""
          }
        }
      }
    },
    "final_conclusion": {
      "type": "string",
      "description": "The memo's overall conclusion or thesis statement (if present)"
    },
    "stateful_metadata": {
      "type": "object",
      "description": "Metadata for stateful memory ablation experiments",
      "properties": {
        "review_cycle": {
          "type": "integer",
          "description": "Which review cycle this case belongs to (1, 2, or 3)",
          "minimum": 1,
          "maximum": 3
        },
        "canonical_claims_introduced": {
          "type": "array",
          "description": "Canonical claim IDs first introduced in this case",
          "items": { "type": "string" }
        },
        "canonical_claims_repeated": {
          "type": "array",
          "description": "Canonical claim IDs that reappear from earlier cycles",
          "items": { "type": "string" }
        }
      }
    },
    "metadata": {
      "type": "object",
      "description": "Additional metadata",
      "properties": {
        "created_by": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" },
        "version": { "type": "string" }
      }
    }
  }
}
